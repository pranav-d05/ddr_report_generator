# ─── LangSmith Observability ────────────────────────────────────────────────────
# Get your free API key at: https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=true to enable — leave false (or unset) to disable.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ddr-report-generator
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com   # default, change only for self-hosted

# ─── LLM via OpenRouter ──────────────────────────────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use — Llama 3.3 70B is free-tier on OpenRouter
# Other options: google/gemini-flash-1.5 | anthropic/claude-3-haiku | openai/gpt-4o-mini
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ─── Embeddings (local, no API cost) ─────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Add HuggingFace token to resolve the rate limits / downloads warning
HF_TOKEN=your-huggingface-token-here

# ─── Vector Store ─────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=ddr_inspection_docs

# ─── Paths ────────────────────────────────────────────────────────────────────
INPUT_DIR=./inputs
OUTPUT_DIR=./outputs
IMAGES_DIR=./outputs/images

# ─── Default PDF filenames (must match files in inputs/) ─────────────────────
INSPECTION_PDF=Sample_Report.pdf
THERMAL_PDF=Thermal_Images.pdf

# ─── Chunking Config ──────────────────────────────────────────────────────────
# Larger chunks preserve the "Impacted Area N / Negative side / Positive side"
# structure of the inspection report intact within a single chunk.
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ─── Report Config ────────────────────────────────────────────────────────────
REPORT_TITLE=Detailed Diagnosis Report
COMPANY_NAME=UrbanRoof Private Limited
COMPANY_WEBSITE=www.urbanroof.in
