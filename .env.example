# ─── LLM via Cohere ───────────────────────────────────────────────────────────
# Get your free API key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key-here

# Cohere model — command-r-plus-08-2024 is the best free-tier option
# Other options: command-r-08-2024 | command-light | command-r-plus
COHERE_MODEL=command-r-plus-08-2024

# ─── Embeddings (local, no API cost) ─────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── Vector Store ─────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=ddr_inspection_docs

# ─── Paths ────────────────────────────────────────────────────────────────────
INPUT_DIR=./inputs
OUTPUT_DIR=./outputs
IMAGES_DIR=./outputs/images

# ─── Default PDF filenames (must match files in inputs/) ─────────────────────
INSPECTION_PDF=Sample_Report.pdf
THERMAL_PDF=Thermal_Images.pdf

# ─── Chunking Config ──────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ─── Report Config ────────────────────────────────────────────────────────────
REPORT_TITLE=Detailed Diagnosis Report
COMPANY_NAME=UrbanRoof Private Limited
COMPANY_WEBSITE=www.urbanroof.in
